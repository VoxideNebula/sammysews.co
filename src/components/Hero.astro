---
import { Image } from 'astro:assets';
---

<section class="hero" id="home">
  <div class="hero-left">
    <p class="hero-eyebrow">Handcrafted with love</p>
    <h1 class="hero-title">
      Crafted<br>
      to <em>Fit You</em><br>
      Perfectly.
    </h1>
    <p class="hero-subtitle">
      Bespoke clothing, expert alterations,<br>
      and artful repairs — made just for you.
    </p>
    <a href="#gallery" class="hero-cta">
      See the Work <span class="hero-cta-arrow">→</span>
    </a>
    <div class="stitch-v"></div>
  </div>
  <div class="hero-right">
    <!--
      Replace the src below with your actual hero/portrait image.
      e.g. src="/images/hero.jpg"
    -->
    <Image
      src="/images/hero.jpg"
      alt="Beautiful handcrafted garment"
      width={800}
      height={1000}
      format="webp"
      loading="eager"
    />
  </div>
</section>
