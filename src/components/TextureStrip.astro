    <Image src="/images/texture-1.jpg" alt="Fabric texture" width={600} height={400} format="webp" />
  </div>
  <div class="texture-strip-item">
    <Image src="/images/texture-2.jpg" alt="Close-up stitching" width={600} height={400} format="webp" />
  </div>
  <div class="texture-strip-item">
    <Image src="/images/texture-3.jpg" alt="Fabric detail" width={600} height={400} format="webp" />
  </div>
</div>
